                                                    <title xml:lang="en" ref="https://biblia-arabica.com/work/3">Book of Job</title>
                                                    <textLang mainLang="ar"/>
                                                    <note xml:lang="en">Contains 1:8-5:18; 6:26-28:21</note>
                                                </msItem>
                                            </msContents>
